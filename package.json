{
  "name": "liskarm-cc",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" --filter \"./client\" run build",
    "dev": "bash scripts/dev.sh",
    "dev:no-build": "bash scripts/dev.sh --no-build",
    "stop": "bash scripts/dev.sh stop",
    "logs": "bash scripts/dev.sh logs",
    "test": "pnpm -r --filter \"./packages/**\" --filter \"./client\" --filter \"./web\" run test",
    "lint": "oxlint --config .oxlintrc.json packages client web",
    "lint:fix": "oxlint --config .oxlintrc.json --fix packages client web",
    "typecheck": "pnpm -r --filter \"./packages/**\" --filter \"./client\" run typecheck",
    "deps:check": "depcruise --config .dependency-cruiser.cjs packages client",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .prettierignore",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "oxlint --fix"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@types/node": "^26.0.0",
    "dependency-cruiser": "^16.0.0",
    "husky": "^9",
    "lint-staged": "^15",
    "oxlint": "^1.70.0",
    "prettier": "^3",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "zod": "^3.25.0"
  }
}
