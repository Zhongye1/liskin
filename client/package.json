    "lint": "oxlint src test"
  },
  "dependencies": {
    "@liskin/config": "workspace:^",
    "@liskin/core": "workspace:^",
    "@liskin/llm": "workspace:^",
    "@liskin/protocol": "workspace:^",
    "@liskin/server": "workspace:^",
    "@liskin/tools": "workspace:^",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2"
  }
